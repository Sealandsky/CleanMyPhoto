    "• Subscription will auto-renew unless turned off at least 24 hours before the current period ends." : {
      "localizations" : {
        "en" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "• Subscription will auto-renew unless turned off at least 24 hours before the current period ends."
          }
        },
        "zh-Hans" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "• 订阅将自动续订，除非在当前期间结束前至少 24 小时关闭自动续订"
          }
        }
      }
    },
    "• You can manage your subscription and turn off auto-renewal after purchase." : {
      "localizations" : {
        "en" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "• You can manage your subscription and turn off auto-renewal after purchase."
          }
        },
        "zh-Hans" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "• 用户可以管理订阅，购买后可以关闭自动续订"
          }
        }
      }
    },
    "• Your account will be charged for renewal within 24 hours before the current period ends." : {
      "localizations" : {
        "en" : {
